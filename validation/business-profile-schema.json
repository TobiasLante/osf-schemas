{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://osf-schemas/validation/business-profile-schema.json",
  "title": "OSF Business Profile (v3, IT-Edge Welle 1)",
  "description": "Schema for files under profiles/business/*.json — used by IT-Edges (PostgreSQL pollers) to type event-world entities. Strict separation from telemetry (machine BDE/ProcessData).",
  "type": "object",
  "required": ["profileId", "version", "displayName", "category", "attributes", "kgNodeLabel", "kgIdProperty"],
  "properties": {
    "profileId": {
      "type": "string",
      "pattern": "^SMProfile-[A-Z][A-Za-z0-9]+$",
      "description": "Globally unique profile ID, prefix SMProfile-"
    },
    "version": {
      "type": "string",
      "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"
    },
    "standard": {
      "type": "string",
      "enum": ["CESMII", "OSF", "ISA-95"]
    },
    "displayName": {"type": "string"},
    "category": {
      "type": "string",
      "enum": ["business"],
      "description": "Business profiles only — telemetry profiles live in profiles/machines/."
    },
    "description": {"type": "string"},
    "parentType": {"type": ["string", "null"]},
    "attributes": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["name", "dataType", "category"],
        "properties": {
          "name": {"type": "string"},
          "dataType": {
            "type": "string",
            "enum": ["String", "Int32", "Int64", "Float", "Double", "Boolean", "DateTime", "Json"]
          },
          "category": {"type": "string"},
          "isKey": {"type": "boolean"},
          "description": {"type": "string"},
          "enum": {"type": "array"},
          "unit": {"type": "string"}
        },
        "additionalProperties": false
      }
    },
    "relationships": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["type", "target"],
        "properties": {
          "type": {"type": "string"},
          "target": {"type": "string"},
          "targetIdProp": {"type": "string"},
          "timeBounded": {"type": "boolean"},
          "description": {"type": "string"}
        },
        "additionalProperties": false
      }
    },
    "kgNodeLabel": {"type": "string"},
    "kgIdProperty": {"type": "string"}
  },
  "additionalProperties": false
}
