{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://openshopfloor.org/schemas/machine-type-alias-schema.json",
  "title": "Machine-type alias map",
  "description": "Operator vocabulary for a machine class -> the SM profile that models it. Consumed by discovery to resolve `machineType` against committed profiles.",
  "type": "object",
  "additionalProperties": false,
  "required": ["mapId", "version", "aliases"],
  "properties": {
    "mapId": { "const": "machine-type-aliases" },
    "version": { "type": "string", "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$" },
    "description": { "type": "string" },
    "aliases": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["profileRef", "terms"],
        "properties": {
          "profileRef": { "type": "string", "pattern": "^SMProfile-" },
          "terms": {
            "type": "array",
            "minItems": 1,
            "items": { "type": "string", "minLength": 2 }
          }
        }
      }
    }
  }
}
