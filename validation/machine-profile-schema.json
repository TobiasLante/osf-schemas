{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://osf-schemas/validation/machine-profile-schema.json",
  "title": "OSF Machine SM Profile (v3, CAPT-V3-PROFILE-PROPS)",
  "description": "Schema for files under profiles/machines/*.json — OT-Edge SMProfiles. Each variable carries the v3 wire-class / scope / promotion contract. Strict separation from business profiles (profiles/business/*.json, IT-Edge). NOTE: this is the variable-shape validator for telemetry profiles — distinct from machine-spec-schema.json which types MachineSpec KG nodes (manufacturer datasheets).",
  "type": "object",
  "required": [
    "profileId",
    "version",
    "displayName",
    "attributes"
  ],
  "properties": {
    "profileId": {
      "type": "string",
      "pattern": "^SMProfile-[A-Za-z0-9][A-Za-z0-9-]+$",
      "description": "Globally unique profile ID, prefix SMProfile- (first char after prefix may be a digit, e.g. SMProfile-5AxisMillingMachine)"
    },
    "version": {
      "type": "string",
      "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"
    },
    "standard": {
      "type": "string",
      "enum": [
        "CESMII",
        "OSF",
        "ISA-95"
      ]
    },
    "displayName": {
      "type": "string"
    },
    "description": {
      "type": "string"
    },
    "parentType": {
      "type": [
        "string",
        "null"
      ]
    },
    "abstract": {
      "type": "boolean"
    },
    "kpiRefs": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "description": "KPI references — composed at-query-time on central, NEVER machine output variables."
    },
    "attributes": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "name",
          "dataType",
          "delivery",
          "scope",
          "promotion"
        ],
        "properties": {
          "name": {
            "type": "string"
          },
          "dataType": {
            "type": "string",
            "enum": [
              "String",
              "Int32",
              "Int64",
              "Float",
              "Double",
              "Boolean",
              "DateTime",
              "Json"
            ]
          },
          "category": {
            "type": "string"
          },
          "required": {
            "type": "boolean"
          },
          "description": {
            "type": "string"
          },
          "enum": {
            "type": "array"
          },
          "unit": {
            "type": "string"
          },
          "polling": {
            "type": "string"
          },
          "delivery": {
            "type": "string",
            "enum": [
              "telemetry",
              "transactional"
            ],
            "description": "telemetry = best-effort NATS JetStream publish, Sample-Verlust bei Disconnect OK. transactional = JetStream Pub-Ack + Outbox-Retry, niemals verloren."
          },
          "scope": {
            "type": "string",
            "enum": [
              "edge",
              "hub"
            ],
            "description": "edge = bleibt auf der .99-Edge-Timescale, NIE auf der .150-Zentral. hub = MUSS auf der .150 (uns_history Postgres / KG) ankommen."
          },
          "promotion": {
            "type": "string",
            "enum": [
              "raw",
              "aggregate",
              "on_change",
              "on_cycle_end"
            ],
            "description": "raw = jedes OPC-UA-Sample (nur bei scope=edge sinnvoll). aggregate = Edge rechnet 5-min Bucket (Dauern/Counts, KEINE Quoten). on_change = OPC-UA DataChangeFilter, publish nur bei Wertaenderung. on_cycle_end = 1x pro abgeschlossenem Maschinen-Cycle (B-Snapshot)."
          }
        },
        "additionalProperties": false,
        "allOf": [
          {
            "if": {
              "properties": {
                "promotion": {
                  "const": "raw"
                }
              }
            },
            "then": {
              "properties": {
                "scope": {
                  "const": "edge"
                }
              },
              "description": "promotion=raw ist nur mit scope=edge zulaessig — Roh-Samples werden nie zur Zentral promoted."
            }
          }
        ]
      }
    },
    "relationships": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "type",
          "target"
        ],
        "properties": {
          "type": {
            "type": "string"
          },
          "target": {
            "type": "string"
          },
          "targetIdProp": {
            "type": "string"
          },
          "description": {
            "type": "string"
          }
        },
        "additionalProperties": false
      }
    },
    "kgNodeLabel": {
      "type": "string"
    },
    "kgIdProperty": {
      "type": "string"
    },
    "companionSpec": {
      "type": "string"
    },
    "opcuaTypeDefinition": {
      "type": "string"
    },
    "deviceClass": {
      "type": "string"
    },
    "isa95": {
      "type": "object",
      "description": "ISA-95/MOM-Alignment (additiv): Part-2-Objektmodell + Part-3-MOM-Domäne. objectModel 'Extension' = Standard kennt das Objekt nicht.",
      "additionalProperties": false,
      "required": [
        "objectModel"
      ],
      "properties": {
        "objectModel": {
          "type": "string",
          "minLength": 1
        },
        "equipmentClass": {
          "type": "string"
        },
        "equipmentLevel": {
          "type": "string",
          "enum": [
            "Enterprise",
            "Site",
            "Area",
            "ProcessCell",
            "Unit",
            "ProductionLine",
            "WorkCell",
            "ProductionUnit",
            "StorageZone",
            "StorageUnit",
            "WorkCenter",
            "WorkUnit"
          ]
        },
        "level": {
          "type": "integer",
          "enum": [
            2,
            3,
            4
          ]
        },
        "momDomain": {
          "type": "string",
          "enum": [
            "production",
            "quality",
            "inventory",
            "maintenance"
          ]
        },
        "extension": {
          "type": "boolean"
        },
        "note": {
          "type": "string"
        },
        "propertyMap": {
          "type": "object",
          "additionalProperties": {
            "type": "string"
          }
        }
      }
    }
  },
  "additionalProperties": false
}