  "notes": {
    "hierarchy": "ISA-95 Enterprise → Site → Area → Line → Machine, then domain-specific branches",
    "walkerReynoldsCompliance": "Follows UNS principles: single source of truth, event-driven, ISA-95 hierarchy, no point-to-point integrations",
    "machineTopics": "BDE, ProcessData, TMS, Maintenance, Energy are per-machine (segments 0-4 = hierarchy, 5+ = domain)",
    "siteTopics": "ERP, QMS are per-site (segments 0-1 = enterprise/site, 2+ = domain) because they are not machine-specific",
    "scalability": "New machines: add OPC-UA mapping → topics auto-generated. New domains: add domain block here + publisher in simulator"
  }
}