        { "topicAttribute": "Speed_Injection_Actual", "smAttribute": "Speed_Injection" },
        { "topicAttribute": "Speed_Injection_Set", "smAttribute": "Speed_Injection_Set" },
        { "topicAttribute": "Speed_Screw_Actual", "smAttribute": "Speed_Screw_RPM" },
        { "topicAttribute": "Speed_Screw_Set", "smAttribute": "Speed_Screw_RPM_Set" },
        { "topicAttribute": "Speed_Mould_Open_Actual", "smAttribute": "Speed_Mould_Open" },
