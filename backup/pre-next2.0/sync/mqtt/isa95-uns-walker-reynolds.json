{
  "syncId": "isa95-uns-walker-reynolds",
  "mappingId": "ISA-95_Walker_Reynolds",
  "version": "2.1.0",
  "syncType": "mqtt",
  "description": "ISA-95_Walker_Reynolds — Unified Name Space after Walker Reynolds. Machine-scoped domains (BDE, ProcessData, TMS, Maintenance, Energy) use a fixed 7-segment pattern so wildcard filters like '.../7533/+/+' work consistently. Sub-categories are flattened into the attribute name (e.g. 'Temperature_Melting_Actual' instead of 'Temperature/Melting_Actual'). Site-scoped domains (ERP, QMS) use a separate 6-segment pattern documented in their domain block.",
  "broker": {
    "host": "${MQTT_HOST}",
    "port": "${MQTT_PORT}"
  },
  "topicStructure": {
    "pattern": "{enterprise}/{site}/{area}/{line}/{machine}/{domain}/{attribute}",
    "hierarchy": "ISA-95",
    "segments": {
      "enterprise": {
        "index": 0,
        "description": "Enterprise name (e.g. 'ZeroGuess')"
      },
      "site": {
        "index": 1,
        "description": "Plant/Site (e.g. 'Hauptwerk')"
      },
      "area": {
        "index": 2,
        "description": "Production area (e.g. 'Spritzgusshalle', 'CNC-Fertigung')"
      },
      "line": {
        "index": 3,
        "description": "Production line/cell (e.g. 'SGM-1300', 'CNC-Pool')"
      },
      "machine": {
        "index": 4,
        "description": "Machine ID (e.g. 'SGM-004', '7533')"
      },
      "domain": {
        "index": 5,
        "description": "Data domain: BDE, ProcessData, TMS, Maintenance, Energy"
      },
      "attribute": {
        "index": 6,
        "description": "Attribute name (flattened, sub-categories joined with underscore)"
      }
    },
    "subscribeFilters": [
      "+/+/+/+/+/BDE/+",
      "+/+/+/+/+/ProcessData/+",
      "+/+/+/+/+/TMS/+",
      "+/+/+/+/+/Maintenance/+",
      "+/+/+/+/+/Energy/+",
      "+/+/ERP/#",
      "+/+/QMS/#"
    ]
  },
  "payloadSchema": {
    "format": "JSON",
    "valuePath": "$.value",
    "timestampPath": "$.ts",
    "timestampFormat": "ISO8601",
    "unitPath": "$.unit",
    "qualityPath": "$.quality",
    "example": {
      "value": 234.5,
      "ts": "2026-03-22T14:30:00.000Z",
      "unit": "°C",
      "quality": "good"
    }
  },
  "machineIdResolution": {
    "strategy": "topic_segment",
    "segment": 4,
    "description": "Segment 4 is the machine ID, resolved against SM Profile kgIdProperty 'machine_id'"
  },
  "domains": {
    "BDE": {
      "description": "Betriebsdatenerfassung — real-time production counters and status",
      "topicPattern": "{enterprise}/{site}/{area}/{line}/{machine}/BDE/{attribute}",
      "examples": [
        "{enterprise}/{site}/{area}/{line}/SGM-004/BDE/Machine_Status",
        "{enterprise}/{site}/{area}/{line}/SGM-004/BDE/Parts_Good",
        "{enterprise}/{site}/{area}/{line}/SGM-004/BDE/Parts_Scrap",
        "{enterprise}/{site}/{area}/{line}/SGM-004/BDE/Cycle_Time_Actual",
        "{enterprise}/{site}/{area}/{line}/SGM-004/BDE/OEE",
        "{enterprise}/{site}/{area}/{line}/SGM-004/BDE/Availability",
        "{enterprise}/{site}/{area}/{line}/SGM-004/BDE/Performance",
        "{enterprise}/{site}/{area}/{line}/SGM-004/BDE/Quality_Pct",
        "{enterprise}/{site}/{area}/{line}/SGM-004/BDE/Shot_Counter",
        "{enterprise}/{site}/{area}/{line}/SGM-004/BDE/Production_Order",
        "{enterprise}/{site}/{area}/{line}/SGM-004/BDE/Article_ID"
      ],
      "attributeMappings": [
        {
          "topicAttribute": "Machine_Status",
          "smAttribute": "Machine_Status"
        },
        {
          "topicAttribute": "Parts_Good",
          "smAttribute": "Good_Parts"
        },
        {
          "topicAttribute": "Parts_Scrap",
          "smAttribute": "Scrap_Parts"
        },
        {
          "topicAttribute": "Parts_Rework",
          "smAttribute": "Rework_Parts"
        },
        {
          "topicAttribute": "Cycle_Time_Actual",
          "smAttribute": "Cycle_Time_Actual"
        },
        {
          "topicAttribute": "Cycle_Time_Plan",
          "smAttribute": "Cycle_Time_Planned"
        },
        {
          "topicAttribute": "OEE",
          "smAttribute": "OEE"
        },
        {
          "topicAttribute": "Availability",
          "smAttribute": "Availability"
        },
        {
          "topicAttribute": "Performance",
          "smAttribute": "Performance"
        },
        {
          "topicAttribute": "Quality_Pct",
          "smAttribute": "Quality_Pct"
        },
        {
          "topicAttribute": "Shot_Counter",
          "smAttribute": "Shot_Counter"
        },
        {
          "topicAttribute": "Production_Order",
          "smAttribute": "Production_Order"
        },
        {
          "topicAttribute": "Article_ID",
          "smAttribute": "Article_ID"
        }
      ]
    },
    "ProcessData": {
