{
  "syncId": "Sync-UNS-bigdata-downtime",
  "version": "1.0.0",
  "syncType": "mqtt",
  "broker": {
    "host": "192.168.178.150",
    "port": 31883
  },
  "topicStructure": {
    "pattern": "ZeroGuess/Hauptwerk/+/+/bigdata-downtime/+",
    "segments": {
      "enterprise": {
        "index": 0
      },
      "site": {
        "index": 1
      },
      "domain": {
        "index": 2
      },
      "category": {
        "index": 3
      },
      "objectId": {
        "index": 4
      },
      "attribute": {
        "index": 5
      }
    },
    "subscribeFilter": "ZeroGuess/Hauptwerk/#/#/bigdata-downtime/#"
  },
  "payloadSchema": {
    "format": "json",
    "valuePath": "$.value",
    "timestampPath": "$.ts",
