  },
  "attributeMapping": {
    "strategy": "topic-segments",
    "mappings": [
      {
        "topicAttribute": "machine_id",
        "smAttribute": "machine_id"
      },
      {
        "topicAttribute": "machine_name",
        "smAttribute": "machine_name"
      },
      {
        "topicAttribute": "reason",
        "smAttribute": "reason"
      },
      {
        "topicAttribute": "duration_sec",
        "smAttribute": "duration_sec"
      },
      {
        "topicAttribute": "shift_number",
        "smAttribute": "shift_number"
      },
      {
        "topicAttribute": "recorded_at",
        "smAttribute": "recorded_at"
      }
    ]
  },
  "machineIdResolution": {
    "strategy": "topic-segment",
    "segment": 4
  },
  "profileRef": "SMProfile-DowntimeRecord"
}
