  "constraints": {
    "recipe_hotrunner_temp_band": {
      "description": "Recipe / setting parameter: hot-runner temperature must lie within the target band (resolved at runtime via valueFrom recipe:hotrunner_temp_band). Outside -> material degradation / dimensional deviation on the part.",
      "require": {
        "attr": "hotrunnerTempC",
        "op": "between",
        "valueFrom": "recipe:hotrunner_temp_band"
      },
      "severity": "warning",
      "discrepancyClass": "constraint",
      "concern": "operations",
      "mom_category": "quality",
      "accountable_role": "Process Engineering",
      "deviation_class": "recipe",
      "since": "2026-06-17",
      "impact_basis": "HK"
    },
    "recipe_part_mass_band": {
      "description": "Recipe / setting parameter: part mass must lie within the target band (resolved at runtime via valueFrom recipe:part_mass_band; the recipe target is deliberately chosen narrower than the current actual to detect overfilling/drift early). Outside -> over-/under-injection, scrap.",
      "require": {
        "attr": "partMass_g",
        "op": "between",
        "valueFrom": "recipe:part_mass_band"
      },
      "severity": "error",
      "discrepancyClass": "constraint",
      "concern": "operations",
      "mom_category": "quality",
      "accountable_role": "Process Engineering",
      "deviation_class": "recipe",
      "since": "2026-06-17",
      "impact_basis": "HK"
    },
    "recipe_cushion_band": {
      "description": "Recipe / setting parameter: residual material cushion must lie within the target band (resolved at runtime via valueFrom recipe:cushion_band). Outside -> fluctuation in the hold-pressure profile, dimensional deviation.",
      "require": {
        "attr": "cushionMm",
        "op": "between",
        "valueFrom": "recipe:cushion_band"
      },
      "severity": "warning",
      "discrepancyClass": "constraint",
      "concern": "operations",
      "mom_category": "quality",
      "accountable_role": "Process Engineering",
      "deviation_class": "recipe",
      "since": "2026-06-17",
      "impact_basis": "HK"
    },
    "recipe_peak_pressure_band": {
      "description": "Recipe / setting parameter: peak injection pressure must lie within the target band during the active cycle (resolved at runtime via valueFrom recipe:peak_pressure_band). Cycle-gated (inCycle==true), since the pressure falls to 0 between shots.",
      "when": {
        "attr": "inCycle",
        "op": "eq",
        "value": true
      },
      "require": {
        "attr": "peakPressureBar",
        "op": "between",
        "valueFrom": "recipe:peak_pressure_band"
      },
      "severity": "warning",
      "discrepancyClass": "constraint",
      "concern": "operations",
      "mom_category": "quality",
      "accountable_role": "Process Engineering",
      "deviation_class": "recipe",
      "since": "2026-06-17",
      "impact_basis": "HK"
    },
    "recipe_hold_pressure_band": {
      "description": "Recipe / setting parameter: hold pressure must lie within the target band during the active cycle (resolved at runtime via valueFrom recipe:hold_pressure_band). Cycle-gated (inCycle==true), since the pressure falls to 0 between shots.",
      "when": {
        "attr": "inCycle",
        "op": "eq",
        "value": true
      },
      "require": {
        "attr": "holdPressureBar",
        "op": "between",
        "valueFrom": "recipe:hold_pressure_band"
      },
      "severity": "warning",
      "discrepancyClass": "constraint",
      "concern": "operations",
      "mom_category": "quality",
      "accountable_role": "Process Engineering",
      "deviation_class": "recipe",
      "since": "2026-06-17",
      "impact_basis": "HK"
    },
    "equipment_hotrunner_temp_envelope": {
      "description": "Equipment / asset-per-se: hot-runner temperature must stay within the machine's safe operating envelope, independent of the running recipe. Outside [180,270] degC -> heater / thermocouple / controller fault (a machine problem regardless of the article). Deliberately wider than the recipe band on the same attribute. LITERAL value = machine-spec SSOT — adjust to the machine spec.",
      "require": {
        "attr": "hotrunnerTempC",
        "op": "between",
        "value": [
          180,
          270
        ]
      },
      "severity": "warning",
      "discrepancyClass": "constraint",
      "concern": "operations",
      "mom_category": "maintenance",
      "accountable_role": "Maintenance",
      "deviation_class": "equipment",
      "since": "2026-06-19",
      "impact_basis": "HK"
    },
    "equipment_peak_pressure_limit": {
      "description": "Equipment / asset-per-se: peak injection pressure must stay below the machine's safe mechanical/hydraulic limit during the active cycle, independent of the running recipe. Above [0,1000] bar -> overpressure / machine fault (not a recipe deviation). Cycle-gated (inCycle==true). LITERAL value = machine-spec SSOT — adjust to the machine spec.",
      "when": {
        "attr": "inCycle",
        "op": "eq",
        "value": true
      },
      "require": {
        "attr": "peakPressureBar",
        "op": "between",
        "value": [
          0,
          1000
        ]
      },
      "severity": "error",
      "discrepancyClass": "constraint",
      "concern": "operations",
      "mom_category": "maintenance",
      "accountable_role": "Maintenance",
      "deviation_class": "equipment",
      "since": "2026-06-19",
      "impact_basis": "HK"
    },
    "hotrunner_control_limits": {
      "description": "Control limits (Warngrenze + Eingriffsgrenze) for the hot-runner temperature — a two-tier escalation band on top of the recipe SOLL. Inside the warn band [225,234] degC = ok; outside warn -> 'warning'-tier alarm (watch); outside the action band [218,241] -> 'error'-tier alarm (intervene). Both tiers stay inside the equipment envelope [180,270] (equipment_hotrunner_temp_envelope). LITERAL bands = static SSOT for the pilot; switch to valueFrom 'recipe:hotrunner_limits' to source them per active recipe. Drives the OT alarm panel with a raise/clear lifecycle (auto-clears when the value returns inside the warn band).",
      "require": {
        "attr": "hotrunnerTempC",
        "op": "within_limits",
        "limits": {
          "warn": [
            225,
            234
          ],
          "action": [
            218,
            241
          ]
        }
      },
      "severity": "warning",
      "discrepancyClass": "control_limit",
      "concern": "operations",
      "mom_category": "quality",
      "accountable_role": "Process Engineering",
      "deviation_class": "recipe",
      "since": "2026-06-23",
      "impact_basis": "HK"
    },
    "recipe_nozzle_temp_band": {
      "description": "Recipe / setting parameter (ASSUMED pilot default): nozzleTempC must lie within the active recipe band (valueFrom recipe:nozzle_temp_band).",
      "require": {
        "attr": "nozzleTempC",
        "op": "between",
        "valueFrom": "recipe:nozzle_temp_band"
      },
      "severity": "warning",
      "discrepancyClass": "constraint",
      "concern": "operations",
      "mom_category": "quality",
      "accountable_role": "Process Engineering",
      "deviation_class": "recipe",
      "since": "2026-06-25",
      "impact_basis": "HK"
    },
    "recipe_back_pressure_band": {
      "description": "Recipe / setting parameter (ASSUMED pilot default): backPressureBar must lie within the active recipe band (valueFrom recipe:back_pressure_band).",
      "require": {
        "attr": "backPressureBar",
        "op": "between",
        "valueFrom": "recipe:back_pressure_band"
      },
      "severity": "warning",
      "discrepancyClass": "constraint",
      "concern": "operations",
      "mom_category": "quality",
      "accountable_role": "Process Engineering",
      "deviation_class": "recipe",
      "since": "2026-06-25",
