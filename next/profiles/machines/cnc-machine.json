  "relationships": [],
  "constraints": {
    "spindle_when_in_cycle": {
      "description": "Bearbeitungszyklus läuft, Spindel dreht aber nicht — Tool-Break / Spindel-Motor-Fehler / Steuerungs-Bug.",
      "when": {
        "attr": "Act_State_InCycle",
        "op": "eq",
        "value": true
      },
      "require": {
        "attr": "Act_Speed_Spindle",
        "op": "gt",
        "value": 0
      },
      "severity": "error",
      "discrepancyClass": "constraint",
      "concern": "operations",
      "mom_category": "production",
      "accountable_role": "Fertigung",
      "since": "2026-06-08"
    },
    "coolant_pressure_when_in_cycle": {
      "description": "Bearbeitungszyklus läuft ohne Kühlmitteldruck — Werkstück-/Tool-Schaden droht.",
      "when": {
        "attr": "Act_State_InCycle",
        "op": "eq",
        "value": true
      },
      "require": {
        "attr": "Act_Pressure_Coolant",
        "op": "gt",
        "value": 0
      },
      "severity": "error",
      "discrepancyClass": "constraint",
      "concern": "operations",
      "mom_category": "production",
      "accountable_role": "Instandhaltung",
      "since": "2026-06-08"
    },
    "tool_wear_in_range": {
      "description": "Tool-Wear muss zwischen 0 und 100 Prozent liegen — Werte außerhalb deuten auf Sensor-/Skalierungs-Fehler.",
      "require": {
        "attr": "Act_Pct_ToolWear",
        "op": "between",
        "value": [
          0,
          100
        ]
      },
      "severity": "warning",
      "discrepancyClass": "constraint",
      "concern": "operations",
      "mom_category": "production",
      "accountable_role": "Instandhaltung",
      "since": "2026-06-08"
    }
  },
