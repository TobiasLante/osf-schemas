{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://osf-schemas/next/validation/business-profile-schema.json",
  "title": "OSF Business SM Profile — next/ (isa95 + constraints facet)",
  "description": "Validator for next/profiles/{erp,qms,...}/*.json business entities (IT-domain, polled by it-edge). Mirrors validation/business-profile-schema.json plus the next/ facets: 'constraints' ($ref constraint-schema.json — evaluated centrally by it-evaluator) and a loosely-typed 'isa95' (the MOM model is evolving; deep semantics are reviewed, not schema-pinned — same pattern as constraints-via-lint). Attributes use 'required' (boolean), aligned with machine-profile-schema.json.",
  "type": "object",
  "required": ["profileId", "version", "displayName", "category", "attributes", "kgNodeLabel", "kgIdProperty"],
  "properties": {
    "profileId": { "type": "string", "pattern": "^SMProfile-[A-Z][A-Za-z0-9-]+$" },
    "version": { "type": "string", "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$" },
    "standard": { "type": "string", "enum": ["CESMII", "OSF", "ISA-95"] },
    "displayName": { "type": "string" },
    "category": { "type": "string", "enum": ["business"] },
    "description": { "type": "string" },
    "parentType": { "type": ["string", "null"] },
    "abstract": { "type": "boolean" },
    "kpiRefs": { "type": "array", "items": { "type": "string" } },
    "attributes": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["name", "dataType", "delivery", "scope", "promotion"],
        "properties": {
          "name": { "type": "string" },
          "dataType": { "type": "string", "enum": ["String", "Int32", "Int64", "Float", "Double", "Boolean", "DateTime", "Json"] },
          "category": { "type": "string" },
          "required": { "type": "boolean" },
          "isKey": { "type": "boolean" },
          "isId": { "type": "boolean" },
          "description": { "type": "string" },
          "enum": { "type": "array" },
          "unit": { "type": "string" },
          "delivery": { "type": "string", "enum": ["telemetry", "transactional"] },
          "scope": { "type": "string", "enum": ["edge", "hub"] },
          "promotion": { "type": "string", "enum": ["raw", "aggregate", "on_change", "on_cycle_end"] }
        },
        "additionalProperties": false
      }
    },
    "relationships": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["type", "target"],
        "properties": {
          "type": { "type": "string" },
          "target": { "type": "string" },
          "targetIdProp": { "type": "string" },
          "timeBounded": { "type": "boolean" },
          "description": { "type": "string" }
        },
        "additionalProperties": false
      }
    },
    "constraints": {
      "$ref": "constraint-schema.json",
      "description": "Optional deviation facet — keyed by constraint id, typed by constraint-schema.json. Evaluated centrally by it-evaluator; cross-reference enforced by next/ci/lint-constraints.mjs."
    },
    "isa95": {
      "type": "object",
      "required": ["objectModel"],
      "properties": { "objectModel": { "type": "string", "minLength": 1 } },
      "additionalProperties": true,
      "description": "ISA-95/MOM mapping, loosely typed (evolving model; objectModel/momDomain/level/propertyMap/note — semantics reviewed, not pinned)."
    },
    "kgNodeLabel": { "type": "string" },
    "kgIdProperty": { "type": "string" }
  },
  "additionalProperties": false
}
