{
  "sourceId": "erpdb-purchase-positions",
  "version": "1.1.0",
  "sourceType": "postgresql",
  "profileRef": "SMProfile-PurchaseOrder",
  "connection": {
    "host": "${ERP_DB_HOST}",
    "port": "${ERP_DB_PORT}",
    "database": "erpdb",
    "schema": "llm_test_v3",
    "table": "bestellung_position"
  },
  "columnMappings": [
    {
      "column": "bestellnummer || '-' || position",
