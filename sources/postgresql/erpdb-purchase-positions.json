    },
    {
      "column": "teil_id",
      "smAttribute": "article_no"
    },
    {
      "column": "menge_bestellt",
      "smAttribute": "qty_ordered"
    },
    {
      "column": "menge_geliefert",
      "smAttribute": "qty_delivered"
    },
    {
      "column": "preis_einheit",
      "smAttribute": "unit_price"
    },
    {
      "column": "status",
      "smAttribute": "status"
    }
  ],
  "filter": null,
  "edges": [
    {
      "type": "FOR_MATERIAL",
      "fkColumn": "teil_id",
      "targetIdProp": "article_no"
    }
  ]
}
