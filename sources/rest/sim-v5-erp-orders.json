  },
  {
   "column": "kunde_name",
   "smAttribute": "customer_name"
  },
  {
   "column": "gesamtbetrag",
   "smAttribute": "total_amount"
  },
  {
   "column": "waehrung",
   "smAttribute": "currency"
  },
  {
   "column": "lieferdatum",
   "smAttribute": "due_date"
  },
  {
   "column": "status",
   "smAttribute": "status"
  },
  {
   "column": "prioritaet",
   "smAttribute": "priority"
  },
  {
   "column": "lieferdatum_soll",
   "smAttribute": "due_date_planned",
   "dataType": "DateTime"
  },
  {
   "column": "lieferdatum_ist",
   "smAttribute": "due_date_actual",
   "dataType": "DateTime"
  },
  {
   "column": "geplante_stueckzahl",
