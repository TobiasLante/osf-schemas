{
  "syncId": "Kafka_UNS",
  "version": "2.0.0",
  "syncType": "kafka",
  "description": "Kafka_UNS — Event-driven sync via Apache Kafka. One topic per entity type, JSON payloads, key = entity ID. Full object per message (not single attributes like MQTT).",
  "kafka": {
    "bootstrapServers": "${KAFKA_BOOTSTRAP_SERVERS}",
    "consumerGroup": "osf-kg-builder",
    "securityProtocol": "PLAINTEXT",
    "schemaRegistry": "${KAFKA_SCHEMA_REGISTRY}",
    "topics": [
      {
        "topic": "factory.bde.events",
        "profileRef": "SMProfile-InjectionMoldingMachine",
        "keyIdProp": "machine_id",
        "payloadMapping": {
          "machine_id": "machine_id",
          "machine_status": "Machine_Status",
          "good_parts": "Good_Parts",
          "scrap_parts": "Scrap_Parts",
          "cycle_time_actual": "Cycle_Time_Actual",
          "oee": "OEE",
          "availability": "Availability",
          "performance": "Performance",
          "quality_pct": "Quality_Pct",
          "production_order": "Production_Order",
          "article_id": "Article_ID"
        }
      },
      {
        "topic": "factory.process-data",
        "profileRef": "SMProfile-InjectionMoldingMachine",
        "keyIdProp": "machine_id",
        "payloadMapping": {
          "machine_id": "machine_id",
          "temp_melting": "Act_Temp_Melting",
          "temp_melting_set": "Set_Temp_Melting",
          "temp_nozzle": "Act_Temp_Nozzle",
          "temp_nozzle_set": "Set_Temp_Nozzle",
          "temp_mould_fixed": "Act_Temp_MouldFixed",
          "temp_mould_moving": "Act_Temp_MouldMoving",
          "temp_oil": "Act_Temp_Oil",
          "pressure_holding": "Act_Pressure_Holding",
          "pressure_holding_set": "Set_Pressure_Holding",
          "pressure_injection_max": "Act_Pressure_InjectionMax",
          "pressure_back": "Act_Pressure_Back",
          "speed_injection": "Act_Speed_Injection",
          "speed_injection_set": "Set_Speed_Injection",
          "speed_screw_rpm": "Act_Speed_ScrewRPM",
          "vol_shot": "Act_Vol_Shot",
          "vol_shot_set": "Set_Vol_Shot",
          "vol_cushion": "Act_Vol_Cushion",
          "force_closing": "Act_Force_Closing",
          "torque_screw": "Act_Torque_Screw",
          "time_filling": "Act_Time_Filling",
          "time_holding": "Act_Time_Holding",
          "time_cooling": "Act_Time_Cooling",
          "time_injection": "Act_Time_Injection",
          "energy_heating_kwh": "Act_Energy_Heating",
          "energy_drive_kwh": "Act_Energy_Drive",
          "energy_power_current_kwh": "Act_Energy_PowerCurrent"
        }
      },
      {
        "topic": "factory.erp.customer-orders",
        "profileRef": "SMProfile-CustomerOrder",
        "keyIdProp": "order_no",
        "payloadMapping": {
          "order_no": "order_no",
          "customer": "customer",
          "article_no": "article_no",
          "quantity": "quantity",
          "due_date": "due_date",
          "status": "status"
        }
      },
      {
        "topic": "factory.erp.production-orders",
        "profileRef": "SMProfile-ProductionOrder",
        "keyIdProp": "order_no",
        "payloadMapping": {
          "order_no": "order_no",
          "article_no": "article_no",
          "machine_no": "machine_no",
          "planned_qty": "planned_qty",
          "produced_qty": "produced_qty",
          "status": "status"
        }
      },
      {
        "topic": "factory.qms.notifications",
        "profileRef": "SMProfile-QualityNotification",
        "keyIdProp": "notification_no",
        "payloadMapping": {
          "notification_no": "notification_no",
          "article_no": "article_no",
          "type": "type",
          "status": "status",
          "description": "description"
        }
      },
      {
        "topic": "factory.maintenance.events",
        "profileRef": "SMProfile-MaintenanceOrder",
        "keyIdProp": "order_no",
        "payloadMapping": {
          "machine_id": "machine_id",
          "order_no": "order_no",
          "type": "type",
          "status": "status",
          "priority": "priority"
        }
      }
    ]
  },
  "notes": {
    "vs_mqtt": "Kafka guarantees ordering per key (partition), has replay capability. MQTT is better for low-latency single-attribute updates.",
    "cdc_integration": "Use Debezium CDC to capture database changes and publish to Kafka automatically."
  }
}
