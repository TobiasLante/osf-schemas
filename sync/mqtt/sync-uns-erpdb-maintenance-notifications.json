{
  "syncId": "Sync-UNS-erpdb-maintenance-notifications",
  "version": "1.0.0",
  "syncType": "mqtt",
  "broker": {
    "host": "mqtt-raw",
    "port": 1883
  },
  "topicStructure": {
    "pattern": "ZeroGuess/Hauptwerk/+/+/erpdb-maintenance-notifications/+",
    "segments": {
      "enterprise": {
        "index": 0
      },
      "site": {
        "index": 1
      },
      "domain": {
        "index": 2
      },
      "category": {
        "index": 3
      },
      "objectId": {
        "index": 4
      },
      "attribute": {
        "index": 5
      }
    },
    "subscribeFilter": "ZeroGuess/Hauptwerk/#/#/erpdb-maintenance-notifications/#"
  },
  "payloadSchema": {
    "format": "json",
    "valuePath": "$.value",
    "timestampPath": "$.ts",
    "timestampFormat": "ISO8601"
  },
  "attributeMapping": {
    "strategy": "topic-segments",
    "mappings": [
      {
        "topicAttribute": "machine_no",
        "smAttribute": "machine_no"
      },
      {
        "topicAttribute": "notification_type",
        "smAttribute": "notification_type"
      },
      {
        "topicAttribute": "priority",
        "smAttribute": "priority"
      },
      {
        "topicAttribute": "status",
        "smAttribute": "status"
      },
      {
        "topicAttribute": "description",
        "smAttribute": "description"
      },
      {
        "topicAttribute": "downtime_minutes",
        "smAttribute": "downtime_minutes"
      },
      {
        "topicAttribute": "root_cause",
        "smAttribute": "root_cause"
      },
      {
        "topicAttribute": "reported_by",
        "smAttribute": "reported_by"
      }
    ]
  },
  "machineIdResolution": {
    "strategy": "topic-segment",
    "segment": 4
  },
  "profileRef": "SMProfile-MaintenanceNotification"
}