{
  "syncId": "shared-uns-factory-sim-v3",
  "mappingId": "#shared.uns",
  "version": "2.0.0",
  "syncType": "mqtt",
  "description": "#shared.uns — Unified MQTT topic structure (6 segments: Factory/site/type/machineId/category/attribute). Site + asset type come from source.location, machineId from source.machineId, category from source.dataCategory, attribute from nodeMappings[].smAttribute. Single source of truth for all exporters; per-machine overrides were removed in v2.0.0.",
  "broker": {
    "host": "192.168.178.150",
    "port": 31883
  },
  "topicStructure": {
    "pattern": "Factory/{site}/{type}/{machineId}/{category}/{attribute}",
    "segments": {
      "site": {
        "index": 1,
        "description": "Location site from source.location.site (e.g. 'Kohlgrub', 'Garmisch')"
      },
      "type": {
        "index": 2,
        "description": "Asset type from source.location.type (e.g. 'CNC', 'SGM', 'IMM')"
      },
      "machineId": {
        "index": 3,
        "description": "Machine display name from source.machineId (e.g. 'CNC-01', 'SGM-002', '7533')"
      },
      "category": {
        "index": 4,
        "description": "Data category from source.dataCategory (BDE | ProcessData)"
      },
      "attribute": {
        "index": 5,
        "description": "Topic attribute name; matches smAttribute from nodeMappings by default"
      }
    },
    "subscribeFilter": "Factory/+/+/+/+/+"
  },
  "payloadSchema": {
    "format": "JSON",
    "timestampFormat": "ISO8601",
    "valuePath": "$.Value",
    "timestampPath": "$.timestamp",
    "unitPath": "$.Unit",
    "definitionPath": "$.Definition",
    "datatypePath": "$.Datatype",
    "qualityPath": "$.ValueQualityQualifier",
    "originPath": "$.ValueOriginQualifier",
    "processingPath": "$.ValueProcessingQualifier",
    "fields": {
      "timestamp": {
        "path": "$.timestamp",
        "source": "runtime.iso8601",
        "description": "Publish time of this message (ISO-8601 UTC)",
        "required": true
      },
      "Value": {
        "path": "$.Value",
        "source": "runtime.value",
        "description": "The sampled value itself",
        "required": true
      },
      "Unit": {
        "path": "$.Unit",
        "source": "profile.attribute.unit",
        "description": "Engineering unit (e.g. '°C', 'bar', 'rpm'). Empty string if dimensionless."
      },
      "Definition": {
        "path": "$.Definition",
        "source": "profile.attribute.description",
        "description": "Human-readable description of what this attribute means"
      },
      "Datatype": {
        "path": "$.Datatype",
        "source": "profile.attribute.dataType",
        "description": "SM Profile-declared data type (Float, Int32, Boolean, String, ...)"
      },
      "ValueQualityQualifier": {
        "path": "$.ValueQualityQualifier",
        "source": "const",
        "default": "good",
        "enum": ["good", "uncertain", "bad"],
        "description": "OPC-UA-style quality — fresh samples default to 'good'"
      },
      "ValueOriginQualifier": {
        "path": "$.ValueOriginQualifier",
        "source": "const",
        "default": "measured",
        "enum": ["measured", "simulated", "calculated", "manual"],
        "description": "Where the value originated. i-flow reads OPC-UA, so 'measured'."
      },
      "ValueProcessingQualifier": {
        "path": "$.ValueProcessingQualifier",
        "source": "const",
        "default": "last",
        "enum": ["last", "first", "averaged", "min", "max"],
        "description": "How the sample was selected within the publish interval"
      }
    },
    "_note": "Top-level *Path keys are maintained alongside `fields` above for backwards compatibility with readers that predate v1.4.0. New code should prefer `fields` since it carries source/default metadata per entry."
  },
  "attributeMapping": {
