{
  "syncId": "sync-uns-9014",
  "mappingId": "#shared.uns.9014",
  "version": "2.0.0",
  "syncType": "mqtt",
  "machineId": "9014",
  "broker": {
    "host": "192.168.178.150",
    "port": 31883,
    "tls": false
  },
  "topicStructure": {
    "pattern": "Factory/Kohlgrub/CNC/9014/{category}/{attribute}",
    "segments": {
      "factory": {
        "index": 0
      },
      "site": {
        "index": 1
      },
      "type": {
        "index": 2
      },
      "machineId": {
        "index": 3
      },
      "category": {
        "index": 4
      },
      "attribute": {
        "index": 5
      }
    },
    "subscribeFilter": "Factory/Kohlgrub/CNC/9014/+/+"
  },
  "payloadSchema": {
    "format": "json",
    "fields": {
      "timestamp": {
        "path": "$.timestamp",
        "source": "runtime.iso8601",
        "required": true
      },
      "Value": {
        "path": "$.Value",
        "source": "runtime.value",
        "required": true
      },
      "Unit": {
        "path": "$.Unit",
        "source": "profile.attribute.unit",
        "default": ""
      },
      "Definition": {
        "path": "$.Definition",
        "source": "profile.attribute.description",
        "default": ""
      },
      "Datatype": {
        "path": "$.Datatype",
        "source": "profile.attribute.dataType",
        "default": "String"
      },
      "ValueQualityQualifier": {
        "path": "$.ValueQualityQualifier",
        "source": "const",
        "default": "good"
      },
      "ValueOriginQualifier": {
        "path": "$.ValueOriginQualifier",
        "source": "const",
        "default": "measured"
      },
      "ValueProcessingQualifier": {
        "path": "$.ValueProcessingQualifier",
        "source": "const",
        "default": "last"
      }
    }
  }
}