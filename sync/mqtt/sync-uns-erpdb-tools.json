{
  "syncId": "Sync-UNS-erpdb-tools",
  "version": "1.0.0",
  "syncType": "mqtt",
  "broker": {
    "host": "mqtt-raw",
    "port": 1883
  },
  "topicStructure": {
    "pattern": "ZeroGuess/Hauptwerk/+/+/erpdb-tools/+",
    "segments": {
      "enterprise": {
        "index": 0
      },
      "site": {
        "index": 1
      },
      "domain": {
        "index": 2
      },
      "category": {
        "index": 3
      },
      "objectId": {
        "index": 4
      },
      "attribute": {
        "index": 5
      }
    },
    "subscribeFilter": "ZeroGuess/Hauptwerk/#/#/erpdb-tools/#"
  },
  "payloadSchema": {
    "format": "json",
    "valuePath": "$.value",
    "timestampPath": "$.ts",
    "timestampFormat": "ISO8601"
  },
  "attributeMapping": {
    "strategy": "topic-segments",
    "mappings": [
      {
        "topicAttribute": "tool_type_id",
        "smAttribute": "tool_type_id"
      },
      {
        "topicAttribute": "machine",
        "smAttribute": "machine"
      },
      {
        "topicAttribute": "status",
        "smAttribute": "status"
      },
      {
        "topicAttribute": "wear_pct",
        "smAttribute": "wear_pct"
      },
      {
        "topicAttribute": "usage_minutes",
        "smAttribute": "usage_minutes"
      }
    ]
  },
  "machineIdResolution": {
    "strategy": "topic-segment",
    "segment": 4
  },
  "profileRef": "SMProfile-Tool"
}