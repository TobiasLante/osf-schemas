{
  "syncId": "Sync-UNS-wmsdb-quants",
  "version": "1.0.0",
  "syncType": "mqtt",
  "broker": {
    "host": "mqtt-raw",
    "port": 1883
  },
  "topicStructure": {
    "pattern": "ZeroGuess/Hauptwerk/+/+/wmsdb-quants/+",
    "segments": {
      "enterprise": {
        "index": 0
      },
      "site": {
        "index": 1
      },
      "domain": {
        "index": 2
      },
      "category": {
        "index": 3
      },
      "objectId": {
        "index": 4
      },
      "attribute": {
        "index": 5
      }
    },
    "subscribeFilter": "ZeroGuess/Hauptwerk/#/#/wmsdb-quants/#"
  },
  "payloadSchema": {
    "format": "json",
    "valuePath": "$.value",
    "timestampPath": "$.ts",
    "timestampFormat": "ISO8601"
  },
  "attributeMapping": {
    "strategy": "topic-segments",
    "mappings": [
      {
        "topicAttribute": "quant_id",
        "smAttribute": "quant_id"
      },
      {
        "topicAttribute": "article_no",
        "smAttribute": "article_no"
      },
      {
        "topicAttribute": "article_name",
        "smAttribute": "article_name"
      },
      {
        "topicAttribute": "batch",
        "smAttribute": "batch"
      },
      {
        "topicAttribute": "location_key",
        "smAttribute": "location_key"
      },
      {
        "topicAttribute": "quantity",
        "smAttribute": "quantity"
      },
      {
        "topicAttribute": "unit",
        "smAttribute": "unit"
      },
      {
        "topicAttribute": "quality_status",
        "smAttribute": "quality_status"
      },
      {
        "topicAttribute": "origin_type",
        "smAttribute": "origin_type"
      },
      {
        "topicAttribute": "origin_ref",
        "smAttribute": "origin_ref"
      }
    ]
  },
  "machineIdResolution": {
    "strategy": "topic-segment",
    "segment": 4
  },
  "profileRef": "SMProfile-Quant"
}