{
  "syncId": "Sync-UNS-erpdb-articles",
  "version": "1.0.0",
  "syncType": "mqtt",
  "broker": {
    "host": "mqtt-raw",
    "port": 1883
  },
  "topicStructure": {
    "pattern": "ZeroGuess/Hauptwerk/+/+/erpdb-articles/+",
    "segments": {
      "enterprise": {
        "index": 0
      },
      "site": {
        "index": 1
      },
      "domain": {
        "index": 2
      },
      "category": {
        "index": 3
      },
      "objectId": {
        "index": 4
      },
      "attribute": {
        "index": 5
      }
    },
    "subscribeFilter": "ZeroGuess/Hauptwerk/#/#/erpdb-articles/#"
  },
  "payloadSchema": {
    "format": "json",
    "valuePath": "$.value",
    "timestampPath": "$.ts",
    "timestampFormat": "ISO8601"
  },
  "attributeMapping": {
    "strategy": "topic-segments",
    "mappings": [
      {
        "topicAttribute": "article_no",
        "smAttribute": "article_no"
      },
      {
        "topicAttribute": "name",
        "smAttribute": "name"
      },
      {
        "topicAttribute": "type",
        "smAttribute": "type"
      },
      {
        "topicAttribute": "unit",
        "smAttribute": "unit"
      },
      {
        "topicAttribute": "lead_time_days",
        "smAttribute": "lead_time_days"
      },
      {
        "topicAttribute": "machine_group",
        "smAttribute": "machine_group"
      },
      {
        "topicAttribute": "weight_kg",
        "smAttribute": "weight_kg"
      },
      {
        "topicAttribute": "abc_class",
        "smAttribute": "abc_class"
      }
    ]
  },
  "machineIdResolution": {
    "strategy": "topic-segment",
    "segment": 4
  },
  "profileRef": "SMProfile-Article"
}