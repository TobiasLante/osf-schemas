{
  "syncId": "isa95-uns-walker-reynolds",
  "mappingId": "ISA-95_Walker_Reynolds",
  "version": "2.0.0",
  "syncType": "mqtt",
  "description": "ISA-95_Walker_Reynolds — Full Unified Name Space (UNS) after Walker Reynolds, ISA-95 hierarchy with all domains: BDE, ProcessData, ERP, QMS, TMS, Maintenance, Energy",
  "broker": {
    "host": "${MQTT_HOST}",
    "port": "${MQTT_PORT}"
  },
  "topicStructure": {
    "pattern": "{enterprise}/{site}/{area}/{line}/{machine}/{domain}/{category}/{attribute}",
    "hierarchy": "ISA-95",
    "segments": {
      "enterprise": {
        "index": 0,
        "description": "Enterprise name (e.g. 'ZeroGuess')"
      },
      "site": {
        "index": 1,
        "description": "Plant/Site (e.g. 'Hauptwerk')"
      },
      "area": {
        "index": 2,
        "description": "Production area (e.g. 'Spritzgusshalle', 'CNC-Fertigung')"
      },
      "line": {
        "index": 3,
        "description": "Production line/cell (e.g. 'SGM-1300', 'CNC-Pool')"
      },
      "machine": {
        "index": 4,
        "description": "Machine ID (e.g. 'SGM-004', '7533')"
      },
      "domain": {
        "index": 5,
        "description": "Data domain: BDE, ProcessData, ERP, QMS, TMS, Maintenance, Energy"
      },
      "category": {
        "index": 6,
        "description": "Sub-category within domain"
      },
      "attribute": {
        "index": 7,
        "description": "Attribute name"
      }
    },
    "subscribeFilters": [
      "+/+/+/+/+/BDE/#",
      "+/+/+/+/+/ProcessData/#",
      "+/+/+/+/+/ERP/#",
      "+/+/+/+/+/QMS/#",
      "+/+/+/+/+/TMS/#",
      "+/+/+/+/+/Maintenance/#",
      "+/+/+/+/+/Energy/#"
    ]
  },
  "payloadSchema": {
    "format": "JSON",
    "valuePath": "$.value",
    "timestampPath": "$.ts",
    "timestampFormat": "ISO8601",
    "unitPath": "$.unit",
    "qualityPath": "$.quality",
    "example": {
      "value": 234.5,
      "ts": "2026-03-22T14:30:00.000Z",
      "unit": "°C",
      "quality": "good"
    }
  },
  "machineIdResolution": {
    "strategy": "topic_segment",
    "segment": 4,
    "description": "Segment 4 is the machine ID, resolved against SM Profile kgIdProperty 'machine_id'"
  },
  "domains": {
