{
  "syncId": "Sync-UNS-erpdb-machine-types",
  "version": "1.0.0",
  "syncType": "mqtt",
  "broker": {
    "host": "mqtt-raw",
    "port": 1883
  },
  "topicStructure": {
    "pattern": "ZeroGuess/Hauptwerk/+/+/erpdb-machine-types/+",
    "segments": {
      "enterprise": {
        "index": 0
      },
      "site": {
        "index": 1
      },
      "domain": {
        "index": 2
      },
      "category": {
        "index": 3
      },
      "objectId": {
        "index": 4
      },
      "attribute": {
        "index": 5
      }
    },
    "subscribeFilter": "ZeroGuess/Hauptwerk/#/#/erpdb-machine-types/#"
  },
  "payloadSchema": {
    "format": "json",
    "valuePath": "$.value",
    "timestampPath": "$.ts",
    "timestampFormat": "ISO8601"
  },
  "attributeMapping": {
    "strategy": "topic-segments",
    "mappings": [
      {
        "topicAttribute": "name",
        "smAttribute": "name"
      },
      {
        "topicAttribute": "description",
        "smAttribute": "description"
      },
      {
        "topicAttribute": "max_closing_force_kn",
        "smAttribute": "max_closing_force_kn"
      },
      {
        "topicAttribute": "min_closing_force_kn",
        "smAttribute": "min_closing_force_kn"
      }
    ]
  },
  "machineIdResolution": {
    "strategy": "topic-segment",
    "segment": 4
  },
  "profileRef": "SMProfile-MachineType"
}