    {
      "sourceRef": "qmsdb-notifications",
      "changeDetection": "timestamp",
      "timestampColumn": "updated_at",
      "batchSize": 100
    },
    {
      "sourceRef": "qmsdb-corrective-actions",
      "changeDetection": "timestamp",
      "timestampColumn": "updated_at",
      "batchSize": 100
    }
  ]
