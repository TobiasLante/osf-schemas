{
  "profileId": "SMProfile-CustomerOrder",
  "version": "3.0.0",
  "standard": "CESMII",
  "displayName": "Customer Order (Kundenauftrag)",
  "description": "Sales order from customer with delivery commitment",
  "parentType": "Order",
  "attributes": [
    {
      "name": "customer",
      "dataType": "String",
      "category": "Core",
      "delivery": "transactional",
      "scope": "hub",
      "promotion": "on_change"
    },
    {
      "name": "article_no",
      "dataType": "String",
      "category": "Core",
      "delivery": "transactional",
      "scope": "hub",
      "promotion": "on_change"
    },
    {
      "name": "article_name",
      "dataType": "String",
      "category": "Core",
      "delivery": "transactional",
      "scope": "hub",
      "promotion": "on_change"
    },
    {
      "name": "quantity",
      "dataType": "Float",
      "category": "Core",
      "delivery": "transactional",
      "scope": "hub",
      "promotion": "on_change"
    },
    {
      "name": "unit_price",
      "dataType": "Float",
      "category": "Commercial",
      "unit": "EUR",
      "delivery": "transactional",
      "scope": "hub",
      "promotion": "on_change"
    },
    {
      "name": "due_date",
      "dataType": "String",
      "category": "Planning",
      "delivery": "transactional",
      "scope": "hub",
      "promotion": "on_change"
    },
    {
      "name": "production_order_no",
      "dataType": "String",
      "category": "Link",
      "delivery": "transactional",
      "scope": "hub",
      "promotion": "on_change"
    },
    {
      "name": "status",
      "dataType": "String",
      "category": "Planning",
      "delivery": "transactional",
      "scope": "hub",
      "promotion": "on_change"
    },
    {
      "name": "priority",
      "dataType": "String",
      "category": "Planning",
      "delivery": "transactional",
      "scope": "hub",
      "promotion": "on_change"
    },
    {
      "name": "due_date_planned",
      "dataType": "DateTime",
      "category": "Planning",
      "delivery": "transactional",
      "scope": "hub",
      "promotion": "on_change"
    },
    {
      "name": "due_date_actual",
      "dataType": "DateTime",
      "category": "Planning",
      "delivery": "transactional",
      "scope": "hub",
      "promotion": "on_change"
    },
    {
      "name": "qty_planned",
      "dataType": "Int32",
      "category": "Planning",
      "delivery": "transactional",
      "scope": "hub",
      "promotion": "on_change"
    },
    {
      "name": "qty_produced",
      "dataType": "Int32",
      "category": "Planning",
      "delivery": "transactional",
      "scope": "hub",
      "promotion": "on_change"
    }
  ],
  "constraints": {
    "order_overdue": {
      "description": "Offener Auftrag mit überschrittenem Liefertermin (Lieferverzug)",
      "when": { "attr": "status", "op": "eq", "value": "offen" },
      "require": { "attr": "due_date", "op": "gte", "valueAttr": "$now" },
      "severity": "warning",
      "discrepancyClass": "constraint",
      "since": "2026-06-15"
    },
    "late_delivery": {
      "description": "Ist-Lieferdatum liegt nach dem Soll-Liefertermin (Terminverzug)",
      "require": { "attr": "due_date_actual", "op": "lte", "valueAttr": "due_date_planned" },
      "severity": "error",
      "discrepancyClass": "constraint",
      "since": "2026-06-15"
    },
    "qty_shortfall": {
      "description": "Fertiggemeldeter Auftrag mit Mindermenge (produziert < geplant)",
      "when": { "attr": "status", "op": "eq", "value": "fertig" },
      "require": { "attr": "qty_produced", "op": "gte", "valueAttr": "qty_planned" },
      "severity": "error",
      "discrepancyClass": "constraint",
      "since": "2026-06-15"
    }
  },
  "relationships": [
    {
      "type": "FOR_ARTICLE",
      "target": "Article"
    },
    {
      "type": "TRIGGERS",
      "target": "ProductionOrder"
    }
  ],
  "kgNodeLabel": "CustomerOrder",
  "kgIdProperty": "order_no",
  "category": "business",
  "isa95": {
    "objectModel": "OperationsRequest",
    "momDomain": "production",
    "level": 4,
    "propertyMap": {
      "order_no": "OperationsRequest.ID",
      "due_date": "OperationsRequest.EndTime",
      "priority": "OperationsRequest.Priority"
    }
  }
}