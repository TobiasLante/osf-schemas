{
  "$description": "Edge-IPC TimescaleDB instance — Layer A Telemetry+Event topic-blob storage for sgm-001 (Spritzguss). Same shape as edge-cnc-001 — see that file's $description.",
  "instanceId": "edge-sgm-001",
  "kind": "edge",
  "tier": "A",
  "displayName": "Edge TimescaleDB sgm-001",
  "ipcId": "sgm-001",
  "host": "192.168.178.99",
  "internalHost": "timescale",
  "internalPort": 5432,
  "nodePort": 42432,
  "database": "uns_history",
  "user": "postgres",
  "passwordSource": "TIMESCALE_PASSWORD env (default 'edge')",
  "natsDomain": "edge_sgm001",
  "queryRoute": {
    "type": "nats-rr",
    "subjects": {
      "last":  "i3x.values.sgm-001.last",
      "range": "i3x.values.sgm-001.range"
    },
    "handler": "edge-query-mcp"
  },
  "tables": [
    {
      "name": "uns_history",
      "kind": "topic-blob",
      "primaryKey": ["ts", "machine", "variable"],
      "columns": [
        { "name": "ts", "type": "timestamptz", "notNull": true },
        { "name": "enterprise", "type": "text" },
        { "name": "site", "type": "text" },
        { "name": "area", "type": "text" },
        { "name": "line", "type": "text" },
        { "name": "machine", "type": "text", "notNull": true },
        { "name": "domain", "type": "text" },
        { "name": "variable", "type": "text", "notNull": true },
        { "name": "value", "type": "double precision" },
        { "name": "value_text", "type": "text" },
        { "name": "unit", "type": "text" },
        { "name": "topic", "type": "text", "notNull": true }
      ],
      "subjectFilter": "factory.*.*.*.sgm-001.>",
      "domains": ["telemetry", "event", "kpi"]
    }
  ],
  "retention": { "default": "7d" },
  "compression": { "afterAge": "6h", "segmentBy": ["machine", "variable"], "orderBy": "ts DESC" },
  "servedMachines": ["sgm-001"],
  "machineTypes": ["SGM"]
}
