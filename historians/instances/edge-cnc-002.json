{
  "$description": "Edge-IPC TimescaleDB instance — Layer A Telemetry+Event topic-blob storage. Auto-generated by ipc.sh init from .env. Commit this file to osf-schemas/historians/instances/ so the next kg-builder run picks it up and materialises :Historian + STORED_AT relations.",
  "instanceId": "edge-cnc-002",
  "kind": "edge",
  "tier": "A",
  "displayName": "Edge TimescaleDB cnc-002",
  "ipcId": "cnc-002",
  "host": "192.168.178.99",
  "internalHost": "timescale",
  "internalPort": 5432,
  "nodePort": 43432,
  "database": "uns_history",
  "user": "postgres",
  "passwordSource": "TIMESCALE_PASSWORD env (default 'edge')",
  "natsDomain": "edge_cnc002",
  "queryRoute": {
    "type": "nats-rr",
    "subjects": {
      "last":  "i3x.values.cnc-002.last",
      "range": "i3x.values.cnc-002.range"
    },
    "handler": "edge-query-mcp"
  },
  "tables": [
    {
      "name": "uns_history",
      "kind": "topic-blob",
      "primaryKey": ["ts", "machine", "variable"],
      "columns": [
        { "name": "ts",         "type": "timestamptz",      "notNull": true },
        { "name": "enterprise", "type": "text" },
        { "name": "site",       "type": "text" },
        { "name": "area",       "type": "text" },
        { "name": "line",       "type": "text" },
        { "name": "machine",    "type": "text",             "notNull": true },
        { "name": "domain",     "type": "text" },
        { "name": "variable",   "type": "text",             "notNull": true },
        { "name": "value",      "type": "double precision" },
        { "name": "value_text", "type": "text" },
        { "name": "unit",       "type": "text" },
        { "name": "topic",      "type": "text",             "notNull": true }
      ],
      "subjectFilter": "factory.*.*.*.cnc-002.>",
      "domains": ["telemetry", "event", "kpi"]
    }
  ],
  "retention":   { "default": "7d" },
  "compression": { "afterAge": "6h", "segmentBy": ["machine", "variable"], "orderBy": "ts DESC" },
  "servedMachines": ["cnc-002"],
  "machineTypes": ["CNC"]
}
